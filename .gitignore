cat <<EOF > .gitignore
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
node_modules/
bower_components/
vendor/
*.log
*.tmp
*.cache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
config.json
git-push.command
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
EOF